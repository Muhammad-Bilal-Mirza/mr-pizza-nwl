# Local development configuration
# This file is used by Vite during development (pnpm dev)

# Use mock backend for development (no IC replica needed)
VITE_USE_MOCK=true

# Storage gateway URL (optional - can use default)
VITE_STORAGE_GATEWAY_URL=https://blob.caffeine.ai

# For local IC replica testing, uncomment and set these:
# CANISTER_ID_BACKEND=your-local-canister-id
# DFX_NETWORK=local
